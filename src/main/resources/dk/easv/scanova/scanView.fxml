<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="dk.easv.scanova.GUI.ScanViewController"
            prefHeight="800.0" prefWidth="1200.0">

    <!-- TOP TOOLBAR -->
    <top>
        <ToolBar>
            <Button text="Start Scan" fx:id="startScanButton" onAction="#onStartScan"/>
            <Button text="Stop" fx:id="stopButton"/>
            <Separator />

            <Separator />
            <Button text="Export TIFF" fx:id="exportButton"/>
            <Separator />
            <Label text="Profile:" />
            <ComboBox fx:id="profileComboBox" prefWidth="150" />
            <Label text="Box ID:" />
            <TextField fx:id="boxIdField" prefWidth="100" />

            <!-- Logout Button -->
            <Separator />
            <Button text="Logout"
                    onAction="#handleLogout"
                    style="-fx-background-color: #EF4444;
                           -fx-text-fill: white;
                           -fx-font-weight: bold;
                           -fx-background-radius: 5;
                           -fx-cursor: hand;"/>
        </ToolBar>
    </top>

    <!-- LEFT SIDEBAR (FILES grouped by Document) -->
    <left>
        <VBox prefWidth="220" style="-fx-padding: 8; -fx-spacing: 6;">
            <Label text="Documents &amp; Files" style="-fx-font-weight: bold; -fx-font-size: 13;"/>
            <ListView fx:id="fileListView" VBox.vgrow="ALWAYS"/>
            <HBox spacing="5">
                <Button text="↑" fx:id="moveUpButton"/>
                <Button text="↓" fx:id="moveDownButton"/>
                <Button text="Delete" fx:id="deleteButton"/>
            </HBox>
        </VBox>
    </left>

    <!-- CENTER (IMAGE PREVIEW) -->
    <center>
        <fx:include source="imagePreview.fxml" fx:id="imagePreviewComponent"/>
    </center>

    <!-- BOTTOM STATUS BAR -->
    <bottom>
        <HBox spacing="30" style="-fx-padding: 8; -fx-background-color: #f0f0f0;">
            <Label fx:id="scanCountLabel" text="Scans: 0 / 0"/>
            <Label fx:id="documentCountLabel" text="Documents: 0"/>
            <Label fx:id="statusLabel" text="Status: Ready"/>
        </HBox>
    </bottom>

    </BorderPane>